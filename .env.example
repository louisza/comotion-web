# API
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/comotion
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=/tmp/comotion-uploads

# Auth
JWT_SECRET=change-this-in-production
JWT_EXPIRY_HOURS=72
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:3000

# Dev mode: set DEV_USER_ID to skip auth (use a user UUID from the DB)
# DEV_USER_ID=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
